    "sync:blog-dist": "node --experimental-strip-types scripts/sync-blog-to-dist.ts",
    "sync:voice-blog-supabase": "node --experimental-strip-types scripts/sync-voice-cluster-blog-supabase.ts",
    "generate:voice-static": "node --experimental-strip-types scripts/generate-voice-invoicing-static.ts",
    "patch:voice-blog-meta": "node --experimental-strip-types scripts/patch-voice-cluster-blog-meta.ts",
    "generate:legal-static": "node --experimental-strip-types scripts/generate-legal-static.ts",
    "generate:video-blog-static": "node --experimental-strip-types scripts/generate-video-blog-static.ts",
    "verify:blog-deploy": "node --experimental-strip-types scripts/verify-blog-deploy.ts",
    "generate:gmail-static": "node --experimental-strip-types scripts/generate-gmail-landing-static.ts",
    "generate:smash-leads-static": "node --experimental-strip-types scripts/generate-smash-leads-static.ts",
    "generate:pseo-static": "node --experimental-strip-types scripts/generate-pseo-static.ts",
    "verify:pseo": "node --experimental-strip-types scripts/verify-pseo.ts",
    "prerender": "node --experimental-strip-types scripts/prerender-blog.ts",
    "render:pilot-blog": "node --experimental-strip-types scripts/render-pilot-blog-post.ts",
    "sitemap": "node --experimental-strip-types scripts/generate-sitemap.ts",
    "indexnow": "node --experimental-strip-types scripts/indexnow.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.11.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "marked": "^18.0.2",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
